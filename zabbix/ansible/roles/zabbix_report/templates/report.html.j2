<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zabbix Monitoring Report</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; overflow-x: hidden; }
        .sidebar { height: 100vh; position: fixed; top: 0; left: 0; padding-top: 20px; z-index: 1000; box-shadow: 2px 0 5px rgba(0,0,0,0.2); overflow-y: auto; }
        .main-content { margin-left: 17%; padding: 30px; }
        .theme-toggle { cursor: pointer; font-size: 1.5rem; float: right; }
        .card-stat { transition: 0.3s; }
        .card-stat:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important; }
        .nav-link { color: #ccc; padding: 10px 20px; font-size: 0.95rem; }
        .nav-link:hover { color: #fff; background-color: rgba(255,255,255,0.1); border-radius: 5px; }
        .section-header { border-bottom: 2px solid #444; padding-bottom: 10px; margin-bottom: 30px; margin-top: 40px; }
        .metric-label { font-size: 0.8rem; color: #aaa; text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px; }
        .metric-value { font-size: 1.05rem; font-weight: 600; font-family: 'JetBrains Mono', monospace; }
        .progress-bar-container { height: 8px; background-color: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden; margin-top: 8px; }
        .progress-bar-fill { height: 100%; border-radius: 4px; transition: width 0.5s ease-in-out; }
        .host-card { transition: 0.3s; }
        .host-card:hover { transform: translateY(-2px); box-shadow: 0 6px 12px rgba(0,0,0,0.3) !important; }
        .group-header { cursor: pointer; transition: background-color 0.2s; border-radius: 8px; }
        .group-header:hover { background-color: rgba(255,255,255,0.05); }
        .group-badge { font-size: 0.75rem; padding: 4px 10px; }
        .btn-expand { font-size: 0.78rem; padding: 3px 10px; }
        @media (max-width: 768px) {
            .sidebar { position: relative; height: auto; margin-bottom: 20px; }
            .main-content { margin-left: 0; padding: 15px; }
        }
    </style>
</head>
<body>

{% macro server_status_badge(status) %}
  {% if status == 'UP' %}bg-success
  {% elif status == 'DOWN' %}bg-danger
  {% elif status == 'STALE' %}bg-warning text-dark
  {% else %}bg-secondary{% endif %}
{% endmacro %}

{% macro progress_color(val) %}
  {% if val and val != 'N/A' %}
    {% set p = val | float %}
    {% if p >= 90 %}bg-danger
    {% elif p >= 75 %}bg-warning
    {% else %}bg-success{% endif %}
  {% else %}bg-secondary{% endif %}
{% endmacro %}

{% macro render_progress_bar(val) %}
  {% if val and val != 'N/A' %}
    <div class="progress-bar-container" title="{{ val }}%">
        <div class="progress-bar-fill {{ progress_color(val) }}" style="width: {{ [val | float | default(0), 100] | min }}%;"></div>
    </div>
  {% endif %}
{% endmacro %}

    <div class="row g-0">
        <!-- Sidebar -->
        <div class="col-md-2 bg-dark sidebar">
            <h5 class="text-white text-center mb-4"><i class="fas fa-server"></i> Zabbix Report</h5>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" href="#summary"><i class="fas fa-chart-pie me-2"></i> Summary</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#hosts"><i class="fas fa-layer-group me-2"></i> Server Groups</a>
                </li>
                {% set groups_list = zabbix_groups_data | from_json if zabbix_groups_data is string else zabbix_groups_data %}
                {% if groups_list is defined and groups_list | length > 0 %}
                {% for group in groups_list %}
                <li class="nav-item">
                    <a class="nav-link ps-4 small" href="#group-{{ loop.index }}"><i class="fas fa-folder me-1"></i> {{ group.group_name if group is mapping else group }}</a>
                </li>
                {% endfor %}
                {% endif %}
                <li class="nav-item">
                    <a class="nav-link" href="#problems"><i class="fas fa-exclamation-triangle me-2"></i> Problems</a>
                </li>
            </ul>
        </div>

        <!-- Main Content -->
        <div class="col-md-10 main-content">
            <i class="fas fa-moon theme-toggle text-light" id="themeToggle" onclick="toggleTheme()" title="Toggle Theme"></i>

            <div class="text-end text-muted small mb-3">
                <i class="fas fa-clock me-1"></i> Last updated: {{ report_timestamp | default('N/A') }}
            </div>

            <div id="summary">
                <h2 class="section-header">Monitoring Summary</h2>

                <!-- Statistics Cards -->
                <div class="row mb-4">
                    <div class="col-md-3 mb-3">
                        <div class="card bg-primary text-white text-center p-3 h-100 shadow-sm card-stat border-0">
                            <i class="fas fa-server fs-2 mb-2"></i>
                            <h5>Total Servers</h5>
                            <h2 class="display-5 fw-bold">{{ report_summary.total_hosts | default(0) }}</h2>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="card bg-success text-white text-center p-3 h-100 shadow-sm card-stat border-0">
                            <i class="fas fa-check-circle fs-2 mb-2"></i>
                            <h5>Running</h5>
                            <h2 class="display-5 fw-bold">{{ report_summary.running_hosts | default(0) }}</h2>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="card bg-danger text-white text-center p-3 h-100 shadow-sm card-stat border-0">
                            <i class="fas fa-times-circle fs-2 mb-2"></i>
                            <h5>Down</h5>
                            <h2 class="display-5 fw-bold">{{ report_summary.down_hosts | default(0) }}</h2>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="card bg-warning text-dark text-center p-3 h-100 shadow-sm card-stat border-0">
                            <i class="fas fa-clock fs-2 mb-2"></i>
                            <h5>Stale</h5>
                            <h2 class="display-5 fw-bold">{{ report_summary.stale_hosts | default(0) }}</h2>
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-4 mb-3">
                        <div class="card bg-dark border-secondary p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="metric-label">Total Active Problems</div>
                                    <div class="metric-value {% if report_summary.total_problems | int > 0 %}text-danger{% else %}text-success{% endif %} fs-4">{{ report_summary.total_problems | default(0) }}</div>
                                </div>
                                <i class="fas fa-bug {% if report_summary.total_problems | int > 0 %}text-danger{% else %}text-success{% endif %} fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="hosts">
                <div class="d-flex justify-content-between align-items-center section-header">
                    <h2 class="mb-0 border-0">Server Groups</h2>
                    <div>
                        <button class="btn btn-sm btn-outline-success me-1 btn-expand" onclick="expandAll()"><i class="fas fa-expand-alt me-1"></i>Expand All</button>
                        <button class="btn btn-sm btn-outline-secondary btn-expand" onclick="collapseAll()"><i class="fas fa-compress-alt me-1"></i>Collapse All</button>
                    </div>
                </div>

                {% set groups_list = zabbix_groups_data | from_json if zabbix_groups_data is string else zabbix_groups_data %}
                {% if groups_list is defined and groups_list | length > 0 %}
                {% for group in groups_list %}
                {% set group_idx = loop.index %}
                <div class="mb-4" id="group-{{ group_idx }}">
                    <!-- Group Header -->
                    <div class="card bg-dark border-secondary">
                        <div class="card-header group-header d-flex justify-content-between align-items-center px-4 py-3" data-bs-toggle="collapse" data-bs-target="#group-body-{{ group_idx }}">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-folder-open me-2 text-info"></i>
                                <h5 class="mb-0 text-white">{{ group.group_name if group is mapping else group }}</h5>
                                <span class="badge bg-secondary ms-3 group-badge">{{ group.hosts | length if group is mapping else 0 }} server{{ 's' if (group.hosts | length if group is mapping else 0) != 1 }}</span>
                                {% set group_up = group.hosts | selectattr('server_status', 'equalto', 'UP') | list | length if group is mapping else 0 %}
                                {% set group_down = group.hosts | selectattr('server_status', 'equalto', 'DOWN') | list | length if group is mapping else 0 %}
                                {% set group_stale = group.hosts | selectattr('server_status', 'equalto', 'STALE') | list | length if group is mapping else 0 %}
                                <span class="badge bg-success ms-2 group-badge">{{ group_up }} UP</span>
                                {% if group_down > 0 %}
                                <span class="badge bg-danger ms-1 group-badge">{{ group_down }} DOWN</span>
                                {% endif %}
                                {% if group_stale > 0 %}
                                <span class="badge bg-warning text-dark ms-1 group-badge">{{ group_stale }} STALE</span>
                                {% endif %}
                            </div>
                            <i class="fas fa-chevron-down text-muted"></i>
                        </div>

                        <div id="group-body-{{ group_idx }}" class="collapse group-collapse show">
                            <div class="card-body px-3 py-2">
                                {% for host in group.hosts %}
                                {% set host_uid = 'host-' ~ group_idx ~ '-' ~ loop.index %}
                                <div class="card bg-dark border-secondary host-card mb-3">
                                    <div class="card-header border-secondary d-flex justify-content-between align-items-center px-3 py-2" style="cursor: pointer;">
                                        <div class="d-flex align-items-center" data-bs-toggle="collapse" data-bs-target="#{{ host_uid }}" style="flex: 1; cursor: pointer;">
                                            <i class="fas fa-server me-2 text-muted"></i>
                                            <h6 class="mb-0 text-white">{{ host.hostname if host is mapping else 'Unknown' }}</h6>
                                            <span class="badge {{ server_status_badge(host.server_status if host is mapping else 'DOWN') }} ms-2">{{ host.server_status if host is mapping else 'DOWN' }}</span>
                                            <span class="text-muted ms-3 small">{{ host.ip_address if host is mapping else 'N/A' }}</span>
                                        </div>
                                        <button class="btn btn-sm btn-outline-light btn-expand" data-bs-toggle="collapse" data-bs-target="#{{ host_uid }}">
                                            <i class="fas fa-chevron-down"></i>
                                        </button>
                                    </div>

                                    <div id="{{ host_uid }}" class="collapse host-collapse">
                                        <div class="card-body px-4 py-3">
                                            <!-- Metrics Table -->
                                            <table class="table table-dark table-sm table-borderless mb-3">
                                                <tbody>
                                                    <tr>
                                                        <td class="metric-label" style="width:180px;">CPU Usage</td>
                                                        <td class="metric-value text-white">{{ host.cpu_usage_percent if host is mapping else 'N/A' }}%</td>
                                                        <td style="width:40%;">{{ render_progress_bar(host.cpu_usage_percent if host is mapping else 'N/A') }}</td>
                                                    </tr>
                                                    <tr>
                                                        <td class="metric-label">Memory Usage</td>
                                                        <td class="metric-value text-white">{{ host.memory_used_percent if host is mapping else 'N/A' }}% <span class="text-muted small">({{ host.memory_used_gb if host is mapping else 'N/A' }} / {{ host.memory_total_gb if host is mapping else 'N/A' }} GB)</span></td>
                                                        <td>{{ render_progress_bar(host.memory_used_percent if host is mapping else 'N/A') }}</td>
                                                    </tr>
                                                    <tr>
                                                        <td class="metric-label">System Uptime</td>
                                                        <td class="metric-value text-white" colspan="2">{{ host.system_uptime if host is mapping else 'N/A' }}</td>
                                                    </tr>
                                                    <tr>
                                                        <td class="metric-label">Availability (30d)</td>
                                                        <td class="metric-value text-white" colspan="2">
                                                            {% if host.system_availability_percent != 'N/A' and host is mapping %}{{ host.system_availability_percent }}%
                                                            {% else %}<span class="text-muted">Not Configured</span>{% endif %}
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td class="metric-label">Network Traffic</td>
                                                        <td class="metric-value text-white" colspan="2">
                                                            <span class="text-success"><i class="fas fa-arrow-down me-1"></i>IN: {{ host.network_in_mb_s if host is mapping else 'N/A' }} MB/s</span>
                                                            <span class="ms-3 text-warning"><i class="fas fa-arrow-up me-1"></i>OUT: {{ host.network_out_mb_s if host is mapping else 'N/A' }} MB/s</span>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td class="metric-label">Active Problems</td>
                                                        <td class="metric-value {% if host is mapping and host.problem_count | int > 0 %}text-danger{% else %}text-success{% endif %}" colspan="2">{{ host.problem_count if host is mapping else 0 }}</td>
                                                    </tr>
                                                </tbody>
                                            </table>

                                            <!-- Disk Usage -->
                                            {% if host.disks is defined and host.disks | length > 0 and host is mapping %}
                                            <div class="metric-label mb-2">Disk Usage</div>
                                            <div class="row">
                                                {% for disk in host.disks %}
                                                <div class="col-md-4 mb-2">
                                                    <div class="card bg-black bg-opacity-25 border-secondary p-2">
                                                        <div class="d-flex justify-content-between text-white small">
                                                            <span><i class="fas fa-hdd me-1"></i> {{ disk.name if disk is mapping else disk }}</span>
                                                            <span class="fw-bold">{{ disk.used_percent if disk is mapping else 'N/A' }}%</span>
                                                        </div>
                                                        <div class="text-muted" style="font-size: 0.72rem;">{{ disk.used_gb if disk is mapping else 'N/A' }} GB / {{ disk.total_gb if disk is mapping else 'N/A' }} GB &middot; <span class="badge bg-secondary" style="font-size:0.65rem;">{{ disk.type | default('Standard') if disk is mapping else 'Standard' }}</span></div>
                                                        {{ render_progress_bar(disk.used_percent if disk is mapping else 'N/A') }}
                                                    </div>
                                                </div>
                                                {% endfor %}
                                            </div>
                                            {% endif %}

                                            <!-- Recent Problems -->
                                            {% if host.problems is defined and host.problems | length > 0 and host is mapping %}
                                            <div class="mt-3">
                                                <div class="metric-label mb-1">Recent Problems</div>
                                                <table class="table table-dark table-sm mb-0">
                                                    <tbody>
                                                        {% for problem in host.problems[:5] %}
                                                        <tr>
                                                            <td class="small">{{ problem.name if problem is mapping else problem }}</td>
                                                            <td class="small text-end">
                                                                <span class="badge bg-danger">Severity {{ problem.severity if problem is mapping else 'N/A' }}</span>
                                                            </td>
                                                        </tr>
                                                        {% endfor %}
                                                    </tbody>
                                                </table>
                                            </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
                {% else %}
                <div class="alert alert-info bg-opacity-10 border-info px-4 py-3">
                    <i class="fas fa-info-circle me-2"></i> No host data available. Check Zabbix API connection.
                </div>
                {% endif %}
            </div>

            <div id="problems">
                <h2 class="section-header">All Active Problems</h2>

                {% if zabbix_hosts_data is defined %}
                {% set all_problems = zabbix_hosts_data | map(attribute='problems') | flatten | list %}
                {% if all_problems | length > 0 %}
                <div class="card bg-dark border-secondary">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-dark table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Host</th>
                                        <th>Problem</th>
                                        <th>Severity</th>
                                        <th>Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for host in zabbix_hosts_data if host is mapping %}
                                    {% for problem in host.problems if host.problems is defined %}
                                    <tr>
                                        <td class="fw-bold">{{ host.hostname if host is mapping else 'Unknown' }}</td>
                                        <td>{{ problem.name if problem is mapping else problem }}</td>
                                        <td>
                                            <span class="badge bg-danger">{{ problem.severity if problem is mapping else 'N/A' }}</span>
                                        </td>
                                        <td class="small">{{ problem.clock | default('N/A') if problem is mapping else 'N/A' }}</td>
                                    </tr>
                                    {% endfor %}
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                {% else %}
                <div class="alert alert-success bg-opacity-10 border-success px-4 py-3">
                    <i class="fas fa-check-circle me-2"></i> No active problems detected. All systems operational.
                </div>
                {% endif %}
                {% endif %}
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleTheme() {
            const html = document.documentElement;
            const isDark = html.getAttribute('data-bs-theme') === 'dark';
            html.setAttribute('data-bs-theme', isDark ? 'light' : 'dark');
        }

        function expandAll() {
            document.querySelectorAll('.group-collapse').forEach(el => new bootstrap.Collapse(el, {toggle: false}).show());
            document.querySelectorAll('.host-collapse').forEach(el => new bootstrap.Collapse(el, {toggle: false}).show());
        }

        function collapseAll() {
            document.querySelectorAll('.host-collapse').forEach(el => new bootstrap.Collapse(el, {toggle: false}).hide());
            document.querySelectorAll('.group-collapse').forEach(el => new bootstrap.Collapse(el, {toggle: false}).hide());
        }
    </script>
</body>
</html>
