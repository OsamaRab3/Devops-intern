# msmtp system-wide configuration
# Managed by Ansible — do not edit manually
# Docs: https://marlam.de/msmtp/

defaults
    auth           on
    tls            on
    tls_trust_file /etc/ssl/certs/ca-certificates.crt
    logfile        /var/log/msmtp.log

account        default
host           {{ smtp_host }}
port           {{ smtp_port }}
from           {{ smtp_from }}
user           {{ smtp_user }}
password       {{ smtp_password }}
